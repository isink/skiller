# -----------------------------------------------------------------------------
# App runtime (Expo) — read via process.env.EXPO_PUBLIC_*
# -----------------------------------------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# -----------------------------------------------------------------------------
# Import scripts only — NEVER expose to the app bundle.
# Found under: Supabase dashboard → Project Settings → API → service_role key.
# Used by scripts/import/*.ts to upsert skills into the catalog.
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: raise GitHub API rate limits for import-anthropic.ts
# GITHUB_TOKEN=ghp_...
