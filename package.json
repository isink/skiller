{
  "name": "skiller",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "generate-assets": "tsx scripts/generate-assets.ts",
    "import:antigravity": "tsx scripts/import/import-antigravity.ts",
    "import:anthropic": "tsx scripts/import/import-anthropic.ts",
    "import:discover": "tsx scripts/import/import-github-search.ts",
    "import:all": "npm run import:antigravity && npm run import:anthropic && npm run import:discover",
    "enrich:skills": "tsx scripts/enrich/enrich-skills.ts",
    "backfill:stars": "tsx scripts/enrich/backfill-github-stars.ts",
    "backfill:stars:local": "https_proxy=http://127.0.0.1:7890 http_proxy=http://127.0.0.1:7890 npm run backfill:stars",
    "reclassify": "tsx scripts/import/reclassify-misc.ts",
    "sync": "npm run import:all && npm run reclassify && npm run enrich:skills",
    "sync:local": "https_proxy=http://127.0.0.1:7890 http_proxy=http://127.0.0.1:7890 npm run sync"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@supabase/supabase-js": "^2.47.10",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.12",
    "expo-clipboard": "~8.0.0",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "nativewind": "^4.1.23",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-google-mobile-ads": "^16.3.3",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@babel/core": "^7.25.2",
    "@types/node": "^20.17.10",
    "@types/react": "~19.1.10",
    "dotenv": "^16.4.7",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.3.3"
  },
  "private": true
}
